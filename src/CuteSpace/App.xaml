<Application
    x:Class="CuteSpace.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedTheme="Light">
    <Application.Resources>
        <ResourceDictionary>
            <FontFamily x:Key="CuteFont">Comic Sans MS, Segoe UI Variable Text, Segoe UI</FontFamily>
            <FontFamily x:Key="CuteEmojiFont">Segoe UI Emoji, Segoe UI Symbol, Segoe UI</FontFamily>
            <SolidColorBrush x:Key="CuteInkBrush" Color="#3D3148"/>
            <SolidColorBrush x:Key="CuteMutedBrush" Color="#6C6074"/>
            <SolidColorBrush x:Key="CutePinkBrush" Color="#FFE8F4"/>
            <SolidColorBrush x:Key="CuteLavenderBrush" Color="#EEE8FF"/>
            <SolidColorBrush x:Key="CuteMintBrush" Color="#E6FFF4"/>
            <SolidColorBrush x:Key="CuteSkyBrush" Color="#E7F5FF"/>
            <SolidColorBrush x:Key="CuteSurfaceBrush" Color="#FFF9FC"/>
            <SolidColorBrush x:Key="CuteCardBrush" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="CuteBorderBrush" Color="#1F6F5A7A"/>
            <SolidColorBrush x:Key="CuteAccentBrush" Color="#D1488A"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
